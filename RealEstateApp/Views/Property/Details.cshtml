@model RealEstateApp.Models.Property

@{
    ViewData["Title"] = "İlan Detayı";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-3" style="color: #344b61;">@Model.Title</h2>
        <a href="/Property/Index" class="btn btn-secondary"><i class="fa fa-arrow-left"></i> Listeye Dön</a>
    </div>

    <div class="row">
        <div class="col-md-7 mb-4">
            @if (Model.Images != null && Model.Images.Count > 0)
            {
                <div id="propertyCarousel" class="carousel slide shadow rounded" data-bs-ride="carousel">
                    <div class="carousel-inner rounded">
                        @for (int i = 0; i < Model.Images.Count; i++)
                        {
                            var img = Model.Images[i];
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="data:@img.ContentType;base64,@Convert.ToBase64String(img.ImageData)"
                                     class="d-block w-100" style="height: 450px; object-fit: cover;" alt="İlan Görseli">
                            </div>
                        }
                    </div>

                    @if (Model.Images.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#propertyCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                            <span class="visually-hidden">Önceki</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#propertyCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                            <span class="visually-hidden">Sonraki</span>
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="bg-light d-flex justify-content-center align-items-center shadow rounded" style="height: 450px;">
                    <div class="text-center text-muted">
                        <i class="fa fa-image mb-2" style="font-size: 80px;"></i>
                        <h5>Bu ilan için görsel yüklenmemiş.</h5>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-5">
            <div class="card shadow border-0">
                <div class="card-body">
                    <h3 class="fw-bold mb-3" style="color: #198a19;">@Model.Price.ToString("C2")</h3>

                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <strong><i class="fa fa-map-marker-alt text-secondary w-20"></i> Konum</strong>
                            <span>@Model.Location</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <strong><i class="fa fa-home text-secondary w-20"></i> Tür</strong>
                            <span>@Model.Type</span>
                        </li>

                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <strong><i class="fa fa-ruler-combined text-secondary w-20"></i> Metrekare</strong>
                            <span>@Model.SquareMeters m²</span>
                        </li>

                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <strong><i class="fa fa-layer-group text-secondary w-20"></i> Konut Tipi</strong>
                            <span>@Model.PropertyType</span>
                        </li>

                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <strong><i class="fa fa-door-open text-secondary w-20"></i> Oda Sayısı</strong>
                            <span>@Model.RoomCount</span>
                        </li>

                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <strong><i class="fa fa-info-circle text-secondary w-20"></i> Durum</strong>
                            <span class="badge @(Model.Status == "Satıldı" ? "bg-danger" : "bg-success") fs-6">@Model.Status</span>
                        </li>
                    </ul>

                    <h5 class="fw-bold">Açıklama</h5>
                    <p class="text-muted" style="white-space: pre-line;">@Model.Description</p>
                </div>
            </div>
        </div>
    </div>
</div>