@model RealEstateApp.Models.User
@{
    ViewData["Title"] = "Bilgilerimi Güncelle";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white fw-bold">
                    <h5 class="mb-0"><i class="fa fa-user-edit me-2"></i> Hesap Bilgilerimi Düzenle</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditProfile" method="post" enctype="multipart/form-data">
                        <div class="text-center mb-4">
                            @if (Model.ProfilePhoto != null)
                            {
                                <img src="data:@Model.ProfilePhotoType;base64,@Convert.ToBase64String(Model.ProfilePhoto)"
                                     class="rounded-circle shadow-sm border" style="width:120px; height:120px; object-fit:cover;" />
                            }
                            else
                            {
                                <i class="fa fa-user-circle text-secondary" style="font-size: 100px;"></i>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Profil Fotoğrafı Değiştir</label>
                            <input type="file" name="profileImage" class="form-control" accept="image/*" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ad Soyad</label>
                            <input asp-for="FullName" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Kullanıcı Adı</label>
                            <input asp-for="Username" class="form-control" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Yeni Şifre (Değiştirmek istemiyorsanız boş bırakın)</label>
                            <input asp-for="Password" type="password" class="form-control" value="" />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Değişiklikleri Kaydet</button>
                            <a href="/Account/Profile" class="btn btn-outline-secondary">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>