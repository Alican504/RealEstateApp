@model List<RealEstateApp.Models.User>
@{
    ViewData["Title"] = "Danışman Ara";
}

<div class="container mt-4 mb-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white fw-bold py-3">
            <h5 class="mb-0"><i class="fa fa-users me-2"></i> Sistemdeki Danışmanlar</h5>
        </div>
        <div class="card-body bg-light">

            <form asp-action="SearchAgent" method="get" class="mb-4">
                <div class="input-group input-group-lg shadow-sm">
                    <input type="text" name="keyword" class="form-control border-0" placeholder="Danışman adı veya kullanıcı adı arayın..." value="@ViewBag.Keyword">
                    <button class="btn btn-primary px-4" type="submit"><i class="fa fa-search"></i> Ara</button>
                </div>
            </form>

            <div class="row">
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var agent in Model)
                    {
                        <div class="col-md-4 mb-4">
                            <div class="card h-100 border-0 shadow-sm text-center p-4">
                                <div class="mb-3">
                                    <i class="fa fa-user-circle text-secondary" style="font-size: 60px;"></i>
                                </div>
                                <h5 class="fw-bold text-dark mb-1">@agent.FullName</h5>
                                <p class="text-muted small mb-3">@@@agent.Username</p>

                                <a href="/Property/AgentPortfolio/@agent.Id" class="btn btn-outline-primary btn-sm rounded-pill w-100 mt-auto">
                                    <i class="fa fa-briefcase me-1"></i> Portföyünü Gör
                                </a>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <i class="fa fa-search-minus text-muted mb-3" style="font-size: 50px;"></i>
                        <h5 class="text-muted">Aradığınız kritere uygun danışman bulunamadı.</h5>
                    </div>
                }
            </div>

        </div>
    </div>
</div>