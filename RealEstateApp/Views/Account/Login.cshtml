@{
    // Giriş sayfasında yan menünün (sidebar) çıkmaması için Layout'u null yapıyoruz
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - Emlak Yönetim Paneli</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        /* Arka plan görseli ve siyah karartma filtresi (overlay) */
        body {
            /* İlgili linki url('...') kısmının içine yapıştırıyorsun */
            background: linear-gradient(rgba(30, 40, 50, 0.75), rgba(30, 40, 50, 0.75)), url('https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?q=80&w=2075&auto=format&fit=crop') no-repeat center center fixed;
            background-size: cover;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Ortadaki Beyaz Giriş Kartı */
        .login-card {
            background-color: white;
            border-radius: 15px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
            padding: 45px 40px;
            width: 100%;
            max-width: 420px;
        }

        /* Üstteki Logo/İkon Tasarımı */
        .login-icon {
            font-size: 55px;
            color: #2c3e50;
            margin-bottom: 15px;
            position: relative;
            display: inline-block;
        }

            .login-icon .fa-key {
                font-size: 28px;
                position: absolute;
                bottom: 5px;
                right: -10px;
                color: #3498db;
                text-shadow: 2px 2px 0px #fff;
            }

        /* İnput (Metin Kutusu) Tasarımları */
        .form-control {
            background-color: #f4f7f6;
            border: 1px solid #dce3e6;
            border-radius: 8px;
            padding: 14px 15px;
            margin-bottom: 20px;
            font-size: 15px;
        }

            .form-control:focus {
                background-color: #fff;
                border-color: #3498db;
                box-shadow: 0 0 0 0.25rem rgba(52, 152, 219, 0.25);
            }

        /* Buton Tasarımı */
        .btn-login {
            background-color: #2c3e50;
            color: white;
            border: none;
            border-radius: 8px;
            padding: 14px;
            font-weight: bold;
            font-size: 16px;
            width: 100%;
            transition: background-color 0.3s;
        }

            .btn-login:hover {
                background-color: #1a252f;
                color: white;
            }

        /* Kayıt Ol Linki */
        .register-link {
            color: #3498db;
            text-decoration: none;
            font-weight: 500;
            font-size: 14px;
        }

            .register-link:hover {
                text-decoration: underline;
                color: #2980b9;
            }
    </style>
</head>
<body>

    <div class="login-card text-center">

        <div class="login-icon">
            <i class="fa fa-home"></i>
            <i class="fa fa-key"></i>
        </div>
        <h3 class="fw-bold mb-4" style="color: #2c3e50;">Emlak Ofisi Girişi</h3>

        <form asp-action="Login" asp-controller="Account" method="post">

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger text-start py-2 px-3 mb-4 rounded-3 border-0" style="font-size: 14px; background-color: #fee2e2; color: #991b1b;">
                    <i class="fa fa-exclamation-circle me-1"></i> @ViewBag.Error
                </div>
            }

            <div class="text-start">
                <input type="text" name="username" class="form-control" placeholder="Kullanıcı Adı" required autofocus />
            </div>

            <div class="text-start">
                <input type="password" name="password" class="form-control" placeholder="Şifre" required />
            </div>

            <button type="submit" class="btn btn-login mb-4 shadow-sm">Giriş Yap</button>
        </form>

        <div class="mt-1">
            <a href="/Account/Register" class="register-link">Hesabınız yok mu? Kayıt Ol</a>
        </div>

    </div>

</body>
</html>