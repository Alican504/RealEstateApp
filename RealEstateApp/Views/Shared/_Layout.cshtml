<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Emlak Yönetim</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    <style>
        body {
            margin-top: 56px;
            background-color: #f4f4f4;
            color: #333;
        }
        #wrapper {
            padding-left: 225px;
            transition: all 0.4s ease 0s;
        }
        .side-nav {
            position: fixed;
            top: 56px;
            left: 225px;
            width: 225px;
            margin-left: -225px;
            border: none;
            background-color: #333;
            bottom: 0;
            padding-bottom: 40px;
            padding-left: 0;
            list-style: none;
        }
        .side-nav > li > a {
            width: 225px;
            color: #999;
            padding: 15px;
            display: block;
            text-decoration: none;
            border-bottom: 1px solid #444;
        }
        .side-nav > li > a:hover {
            background-color: #000;
            color: #fff;
        }
        #page-wrapper {
            width: 100%;
            padding: 20px;
            background-color: #fff;
            min-height: 100vh;
        }
    </style>
</head>
<body>
    <div id="wrapper">
        <nav class="navbar navbar-dark bg-dark fixed-top">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" href="/Property/Index">EMLAK YÖNETİM PANELİ</a>
            </div>
        </nav>

        <ul class="side-nav">
            <li><a href="/Property/Index"><i class="fa fa-home"></i> İlan İşlemleri</a></li>
            <li><a href="/Account/Profile"><i class="fa fa-user"></i> Danışman Profilim</a></li>
            <li><a href="/Account/SearchAgent"><i class="fa fa-users"></i> Danışman Ara</a></li>
            <li><a href="/Account/Logout" class="text-danger"><i class="fa fa-sign-out-alt"></i> Çıkış Yap</a></li>
        </ul>

        <div id="page-wrapper">

            <div class="container-fluid mt-3">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert" id="autoCloseAlert">
                        <i class="fa fa-check-circle me-2 fs-5 align-middle"></i>
                        <span class="fw-bold">@TempData["Success"]</span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
                        <i class="fa fa-exclamation-triangle me-2 fs-5 align-middle"></i>
                        <span class="fw-bold">@TempData["Error"]</span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            </div>

            <script>
                setTimeout(function() {
                    var alertElement = document.getElementById('autoCloseAlert');
                    if (alertElement) {
                        var bsAlert = new bootstrap.Alert(alertElement);
                        bsAlert.close();
                    }
                }, 3000);
            </script>
            @RenderBody()

        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>